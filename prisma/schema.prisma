generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Blank {
  id         Int      @id @default(autoincrement())
  text       String
  order      Int
  questionId Int
  Question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Option {
  id         Int      @id @default(autoincrement())
  label      String
  text       String
  questionId Int
  Question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Question {
  id     Int      @id @default(autoincrement())
  type   String
  text   String
  answer String
  Blank  Blank[]
  Option Option[]
}
